{
  "mcpServers": {
    "codebrain": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/dist/index.js"]
    },
    "codebase-memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "code-review-graph": {
      "command": "uvx",
      "args": ["code-review-graph"]
    },
    "eslint": {
      "command": "npx",
      "args": ["@eslint/mcp@latest"]
    },
    "socket": {
      "type": "http",
      "url": "https://mcp.socket.dev/"
    },
    "test-coverage": {
      "command": "npx",
      "args": ["-y", "test-coverage-mcp"]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "pare": {
      "command": "npx",
      "args": ["-y", "@paretools/git"]
    },
    "lighthouse": {
      "command": "npx",
      "args": ["-y", "@danielsogl/lighthouse-mcp@latest"]
    }
  }
}
